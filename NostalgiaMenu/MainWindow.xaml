<Window x:Class="NostalgiaMenu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NostalgiaMenu.Controls"
        Title="NostalgiaMenu"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="920"
        Height="560"
        Background="{StaticResource BackgroundBrush}"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition Height="*" />
            <RowDefinition Height="130" />
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource TileBorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="SELECT YOUR GAME"
                       FontSize="38"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       Foreground="{StaticResource NeonGoldBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       >
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFFFD700"
                                      BlurRadius="22"
                                      ShadowDepth="0"
                                      Opacity="0.85" />
                </TextBlock.Effect>
            </TextBlock>
        </Border>

        <!-- ═══ Game Tiles ═══ -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      PanningMode="VerticalOnly"
                      Padding="0">
            <ItemsControl x:Name="GameItemsControl"
                          Margin="24,16,24,16"
                          Focusable="False"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- ═══ Countdown Footer ═══ -->
        <Border Grid.Row="2"
                x:Name="CountdownPanel"
                Visibility="Collapsed"
                Background="{StaticResource FooterBrush}"
                BorderBrush="{StaticResource TileBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Label -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0">
                    <TextBlock Text="Auto-launching in"
                               FontSize="15"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="DefaultGameLabel"
                               FontSize="13"
                               Foreground="{StaticResource NeonGoldBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Ring + number -->
                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <controls:CountdownRing x:Name="CountdownRingControl"
                                            Width="90"
                                            Height="90"
                                            TotalSeconds="60"
                                            RingColor="#FFFFD700"
                                            TrackColor="#FF2A2A2A"
                                            StrokeThickness="7" />
                    <TextBlock x:Name="SecondsText"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{StaticResource NeonGoldBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFFFD700"
                                              BlurRadius="14"
                                              ShadowDepth="0"
                                              Opacity="0.8" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
