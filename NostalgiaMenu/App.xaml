<Application x:Class="NostalgiaMenu.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BackgroundBrush"  Color="#FF0D0D0D" />
        <SolidColorBrush x:Key="TileBorderBrush"  Color="#FF2A2A2A" />
        <SolidColorBrush x:Key="NeonGoldBrush"    Color="#FFFFD700" />
        <SolidColorBrush x:Key="NeonBlueBrush"    Color="#FF00BFFF" />
        <SolidColorBrush x:Key="TextBrush"        Color="#FFEEEEEE" />
        <SolidColorBrush x:Key="FooterBrush"      Color="#FF111111" />
    </Application.Resources>
</Application>
